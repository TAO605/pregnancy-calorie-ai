# Admin
# Required for `npm run start` and production deployments.
ADMIN_DEMO_PASSWORD=

# Security headers
# Enable only when the deployed site is served over HTTPS.
ENABLE_HSTS=false

# Optional Firebase Auth
# If any of these are missing, the app stays in demo-safe mode.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Global free mode switch.
# true = all user-facing features are free and paid entry points are hidden.
# false = restore the normal Stripe subscription system.
NEXT_PUBLIC_ALL_FEATURES_FREE=true

# Optional permanent-free cutoff for early users when paid mode is restored.
# Example: 2026-05-20T00:00:00.000Z
EARLY_FREE_CUTOFF_DATE=
